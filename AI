            // ---------- Helper: find best match ----------
            function findResponse(topic, query) {
                const base = knowledgeBase[topic] || knowledgeBase.coding;
                const lower = query.toLowerCase();

                // Try keyword matching
                const keywordMap = {
                    // coding
                    python: 'python',
                    javascript: 'javascript',
                    js: 'javascript',
                    java: 'default',
                    html: 'default',
                    css: 'default',
                    react: 'default',
                    recursion: 'default',
                    algorithm: 'default',
                    // math
                    calculus: 'calculus',
                    derivative: 'calculus',
                    integral: 'calculus',
                    algebra: 'algebra',
                    quadratic: 'algebra',
                    geometry: 'default',
                    trigonometry: 'default',
                    // language
                    grammar: 'grammar',
                    syntax: 'grammar',
                    etymology: 'etymology',
                    word: 'default',
                    vocabulary: 'default',
                    // science
                    physics: 'physics',
                    force: 'physics',
                    energy: 'physics',
                    biology: 'biology',
                    dna: 'biology',
                    gene: 'biology',
                    chemistry: 'default',
                    quantum: 'default',
                };

                for (const [keyword, key] of Object.entries(keywordMap)) {
                    if (lower.includes(keyword)) {
                        if (base[key]) return base[key];
                    }
                }

                // Check if query is very short / generic
                if (lower.length < 3) {
                    return base.default;
                }

                // Return default for the topic
                return base.default;
            }

            // ---------- Build a "live fetch" message ----------
            function buildLiveFetchMessage(topic, query) {
                const topicNames = {
                    coding: 'coding (MDN · GitHub · Stack Overflow)',
                    math: 'mathematics (Wolfram · Khan Academy)',
                    language: 'language (Oxford · Merriam-Webster)',
                    science: 'science (Nature · ScienceDaily · PubMed)'
                };

                const raw = findResponse(topic, query);

                // Simulate slight delay for realism
                return {
                    text: raw,
                    source: topicNames[topic] || 'web'
                };
            }

            // ---------- Render message ----------
            function addMessage(content, isUser = false) {
                const div = document.createElement('div');
                div.className = 'message';

                if (isUser) {
                    div.innerHTML = `
                        <div class="msg-label" style="color:#4a5b6e;">
                            <i class="fas fa-user"></i> You
                        </div>
                        <div class="msg-content" style="border-left-color:#9aadb9;">
                            <p>${escapeHtml(content)}</p>
                        </div>
                    `;
                } else {
                    // Convert markdown-like syntax to HTML
                    const html = markdownToHtml(content);
                    div.innerHTML = `
                        <div class="msg-label shark">
                            <i class="fas fa-shield-hook"></i> SharksAi · <span style="font-weight:400;text-transform:none;font-size:0.75rem;color:#6a7b8e;"><i class="fas fa-cloud-download-alt"></i> live fetch</span>
                        </div>
                        <div class="msg-content">
                            ${html}
                        </div>
                    `;
                }

                chatWindow.appendChild(div);
                chatWindow.scrollTop = chatWindow.scrollHeight;
            }

            // ---------- Loading indicator ----------
            function showLoading() {
                const div = document.createElement('div');
                div.className = 'message';
                div.id = 'loadingMsg';
                div.innerHTML = `
                    <div class="msg-label shark">
                        <i class="fas fa-shield-hook"></i> SharksAi
                    </div>
                    <div class="msg-content">
                        <div class="spinner">
                            <i class="fas fa-spinner"></i> Fetching from live sources…
                        </div>
                    </div>
                `;
                chatWindow.appendChild(div);
                chatWindow.scrollTop = chatWindow.scrollHeight;
