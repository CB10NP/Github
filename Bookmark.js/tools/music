javascript:(function(){var m=document.querySelectorAll("audio,video")[0];if(!m){alert("No music or audio found on this page!");return;}var d=document.createElement("div");d.style="position:fixed;top:10px;right:10px;z-index:99999;background:#222;color:#fff;padding:15px;border-radius:8px;font-family:sans-serif;box-shadow:0 4px 10px rgba(0,0,0,0.5);";d.innerHTML='<div style="margin-bottom:8px;font-weight:bold;">Music Speed: <span id="spVal">1.0</span>x</div><input type="range" id="spSld" min="0.5" max="3" step="0.1" value="'+m.playbackRate+'" style="width:120px;"><button id="spCls" style="margin-left:10px;background:#f44336;color:#fff;border:none;padding:3px 8px;border-radius:4px;cursor:pointer;">X</button>';document.body.appendChild(d);var s=document.getElementById("spSld");var v=document.getElementById("spVal");s.oninput=function(){m.playbackRate=parseFloat(this.value);v.innerText=this.value;};document.getElementById("spCls").onclick=function(){d.remove();};})();
