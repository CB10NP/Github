javascript:(async()=>{const id=prompt("Paste the Kahoot Quiz UUID:");if(!id)return;try{const res=await fetch(`https://create.kahoot.it/rest/kahoots/${id}/card/?includeKahoot=true`);if(!res.ok)throw new Error(res.status===401?"Private Quiz":"Quiz Not Found");const data=await res.json(),symbols=['🔴','🔵','🟡','🟢'],results=data.kahoot.questions.map((q,i)=>{let answerText="";if(q.type==="quiz"||q.type==="true_false"){const idx=q.choices.findIndex(c=>c.correct);answerText=idx!==-1?`${symbols[idx]} ${q.choices[idx].answer}`:"No correct answer marked"}else if(q.type==="puzzle"){answerText="🧩 Order: "+q.choices.map(c=>c.answer).join(" → ")}else if(q.type==="type_answer"){answerText="⌨️ Acceptable: "+q.choices.filter(c=>c.correct).map(c=>c.answer).join(", ")}else{answerText="Unsupported type: "+q.type}return `<b>Q${i+1}:</b> ${q.question.replace(/<[^>]*>/g,'')}<br><span style="color:#2ecc71">${answerText}</span><hr>`}).join(""),div=document.createElement("div");div.innerHTML=`<div style="position:fixed;top:10px;right:10px;width:350px;max-height:80vh;overflow-y:auto;background:white;color:black;z-index:9999;padding:20px;border-radius:10px;box-shadow:0 10px 25px rgba(0,0,0,0.3);font-family:sans-serif;font-size:14px;border:2px solid #46178f"><h3 style="margin-top:0;color:#46178f">Answers for: ${data.kahoot.title}</h3><button onclick="this.parentElement.remove()" style="position:absolute;top:5px;right:5px;cursor:pointer;border:none;background:none;font-weight:bold">X</button>${results}<p style="font-size:10px;color:gray">Note: Questions might be randomized during the game.</p></div>`;document.body.appendChild(div)}catch(err){alert("Error: "+err.message)}})();
